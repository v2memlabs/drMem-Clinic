# drMem Clinic — örnek ortam (gerçek değerleri commit etmeyin)
# Flutter: --dart-define-from-file veya ayrı define argümanları

# Varsayılan: mock demo
DATA_BACKEND=mock

# Ortam: production | staging | dev (maintenance konsolu için staging/dev)
APP_ENV=production

# Bakım konsolu (yalnız staging/dev + Supabase + operatör flag)
# MAINTENANCE_MODE=true

# Supabase (yalnızca anon key — istemcide service_role KULLANMAYIN)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Örnek çalıştırma (gerçek key olmadan mock kalır):
# flutter run

# Supabase modu (URL + anon key dolu olmalı):
# flutter run --dart-define=DATA_BACKEND=supabase --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...
